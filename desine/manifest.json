{
  "manifest_version": 3,
  "name": "Desine",
  "version": "0.1.0",
  "description": "Scrape fonts, colors, and letter spacing from pages.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Desine",
    "default_icon": {
      "16": "icons/2.png",
      "32": "icons/2.png",
      "48": "icons/2.png",
      "128": "icons/2.png"
    }
  },
  "icons": {
    "16": "icons/2.png",
    "32": "icons/2.png",
    "48": "icons/2.png",
    "128": "icons/2.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
